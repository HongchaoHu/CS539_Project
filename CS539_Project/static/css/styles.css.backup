    margin-bottom: 8px;
}

.query-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
}

.query-chip {
    padding: 8px 16px;
    background: transparent;
    color: var(--primary-color);
    border: 2px solid var(--primary-color);
    border-radius: 0;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    margin-top: 30px;
    transition: all 0.3s;
    position: relative;
    text-transform: uppercase;
    letter-spacing: 2px;
}

