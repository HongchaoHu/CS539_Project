/* ==================== Query Section ==================== */
.query-section {
    margin-top: 30px;
}

.query-section label {
    display: block;
    font-weight: 600;
    margin-bottom: 10px;
    color: var(--text-primary);
}

.query-section textarea {
    width: 100%;
    padding: 15px;
