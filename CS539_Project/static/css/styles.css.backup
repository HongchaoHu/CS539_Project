/* ==================== CSS Variables - Cyberpunk Theme ==================== */
:root {
    --neon-cyan: #00fff9;
    --neon-cyan-dim: #00d9ff;
    --neon-magenta: #ff006e;
    --neon-yellow: #ffcc00;
    --neon-blue: #0080ff;
    
    --primary-color: var(--neon-cyan);
    --primary-hover: var(--neon-cyan-dim);
    --secondary-color: var(--neon-magenta);
    --danger-color: #ff0055;
    --warning-color: var(--neon-yellow);
    --success-color: #00ff88;
    
    --bg-void: #0a0e1a;
    --bg-primary: #0f1419;
    --bg-secondary: #1a1f2e;
    --bg-tertiary: #252b3b;
    
    --text-primary: #e0e7ff;
    --text-secondary: #8892b0;
    --text-tertiary: #495670;
    
    --border-color: rgba(0, 255, 249, 0.15);
    --border-glow: rgba(0, 255, 249, 0.3);
    --border-radius: 2px;
    
    --glow-sm: 0 0 5px rgba(0, 255, 249, 0.3);
    --glow-md: 0 0 10px rgba(0, 255, 249, 0.4);
    --glow-lg: 0 0 20px rgba(0, 255, 249, 0.5);
    --glow-intense: 0 0 30px rgba(0, 255, 249, 0.8);
}
'Courier New', 'Consolas', monospace;
    line-height: 1.6;
    color: var(--text-primary);
    background: var(--bg-void);
    background-image: 
        linear-gradient(rgba(0, 255, 249, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0, 255, 249, 0.03) 1px, transparent 1px);
    background-size: 50px 50px
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    line-height: 1.6;
    color: var(--text-primary);
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    min-height: 100vh;
    padding: 20px;
}

/* ==================== Container ==================== */
.container: 1px solid var(--border-color);
    border-radius: var(--border-radius);
    box-shadow: var(--glow-md), 0 8px 32px rgba(0, 0, 0, 0.9
    margin: 0 auto;
